# Gmail (existing)
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_FROM_NAME=

# OpenObserve / Pulse — error logs on Performance tab
OPENOBSERVE_BASE_URL=https://pulse.salescode.ai
OPENOBSERVE_ORG=demo
# Optional: uat:uat,demo:demo,prod:prod
OPENOBSERVE_ORG_MAP=
OPENOBSERVE_STREAM=channelkart
OPENOBSERVE_JWT=
OPENOBSERVE_SCTOKEN=
# Or paste full browser Cookie header value:
# OPENOBSERVE_COOKIE=jwt=...; sctoken=...
OPENOBSERVE_MAX_HITS=500
OPENOBSERVE_TIME_BUFFER_SECONDS=30
OPENOBSERVE_TIMEOUT_SECONDS=120
# Optional extra SQL AND clause, e.g. service_name = 'channelkart-integration'
OPENOBSERVE_ERROR_SQL_EXTRA=
